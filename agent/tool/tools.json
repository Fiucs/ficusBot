  ],

  // ==========================================
  // Shell 命令工具
  // 对应 ShellTool 类中的方法
  // ==========================================
  "shell_tools": [
    {
      "name": "shell_exec",
      "method": "exec",
      "description": "Execute shell command. Run programs, scripts, file ops. Params: cmd required, cwd optional. Ex: shell_exec({cmd:'python test.py'})",
      "parameters": {
        "type": "object",
        "properties": {
          "cmd": {"type": "string", "description": "要执行的Shell命令"},
          "cwd": {"type": "string", "description": "工作目录，默认当前目录"}
        },
        "required": ["cmd"]
      }
    }
  ],

  // ==========================================
  // 技能工具配置
  // 从 workspace/skills 目录动态加载
  // ==========================================
  "skill_tools": {
    "enabled": true,                    // 是否启用技能系统
    "description": "Load and execute custom skills from workspace/skills directory"
  },

  // ==========================================
  // 记忆系统工具
  // 用于存储和检索长期记忆
  // ==========================================
  "memory_tools": [
    {
      "name": "save_memory",
      "description": "保存信息到长期记忆。存储用户偏好、事实、任务结果等。",
      "parameters": {
        "type": "object",
        "properties": {
          "content": {"type": "string", "description": "要保存的记忆内容，应简洁明了"},
          "memory_type": {
            "type": "string",
            "enum": ["conversation", "fact", "preference", "task", "insight", "document"],
            "description": "记忆类型",
            "default": "conversation"
          },
          "importance": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10,
            "description": "重要性评分，1-10，默认5",
            "default": 5
          },
          "tags": {
            "type": "array",
            "items": {"type": "string"},
            "description": "标签列表"
          }
        },
        "required": ["content"]
      }
    },
    {
      "name": "discover",
      "description": "发现可用资源：工具、技能、记忆。当常驻工具无法满足需求时调用。参数: query(可选,搜索关键词,为空时返回所有), resource_type(可选,tool/memory/all,默认all), top_k(可选,返回数量,默认10), distance_threshold(可选,距离阈值,默认1.0,越小越精确), date_range(可选,日期范围,格式:[start_date,end_date],如:['2026-03-01','2026-03-06'])。",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {"type": "string", "description": "搜索关键词，用于语义匹配。重要：只放内容关键词，不要放时间描述！时间用date_range参数。示例：用户问'3月9号之前的记忆'，query填''或'记忆'，date_range填['2026-01-01','2026-03-09']。用户问'上周讨论的API设计'，query填'API设计'，去掉'上周'。为空时返回所有资源", "default": ""},
          "resource_type": {
            "type": "string",
            "enum": ["all", "memory", "tool"],
            "description": "资源类型：tool(工具/技能) / memory(记忆) / all(全部)",
            "default": "all"
          },
          "top_k": {
            "type": "integer",
            "description": "返回结果数量，默认10",
            "default": 10
          },
          "distance_threshold": {
            "type": "number",
            "description": "L2距离阈值，距离越小越相似。默认1.0，越小结果越精确但可能漏掉相关内容，越大结果越多但可能包含不相关内容。建议范围0.5-1.5",
            "default": 1.0
          },
          "date_range": {
            "type": "array",
            "items": {"type": "string"},
            "minItems": 2,
            "maxItems": 2,
            "description": "日期范围过滤，格式：[start_date, end_date]，如：['2026-03-01', '2026-03-06']"
          }
        },
        "required": []
      }
    },
    {
      "name": "list_memories",
      "description": "列出记忆列表，不需要搜索关键词。当用户询问'我们讨论过什么'、'之前的对话'、'查看所有记忆'时调用。返回记忆总数和指定数量的记忆。",
      "parameters": {
        "type": "object",
        "properties": {
          "top_k": {
            "type": "integer",
            "description": "返回数量，默认10",
            "default": 10
          },
          "full": {
            "type": "boolean",
            "description": "是否返回完整内容，默认true。false时内容会被截断",
            "default": true
          },
          "order": {
            "type": "string",
            "enum": ["desc", "asc"],
            "description": "排序方式：desc(最近的在前，默认) / asc(最早的在前)",
            "default": "desc"
          }
        },
        "required": []
      }
    },
    // {
    //   "name": "delete_memory",
    //   "description": "删除指定ID的记忆。",
    //   "parameters": {
    //     "type": "object",
    //     "properties": {
    //       "memory_id": {"type": "string", "description": "要删除的记忆ID"}
    //     },
    //     "required": ["memory_id"]
    //   }
    // },
    {
      "name": "register_tool",
      "description": "注册新工具到索引。用于创建技能或发现新工具时注册。",
      "parameters": {
        "type": "object",
        "properties": {
          "name": {"type": "string", "description": "工具名称，唯一标识"},
          "description": {"type": "string", "description": "工具功能描述，用于语义搜索匹配"},
          "tool_type": {
            "type": "string",
            "enum": ["skill", "mcp_server", "builtin"],
            "description": "工具类型"
          },
          "source": {"type": "string", "description": "工具来源路径或标识"},
          "enabled": {"type": "boolean", "description": "是否启用，默认true", "default": true},
          "add_to_memory": {"type": "boolean", "description": "是否加入记忆索引（语义搜索），默认true", "default": true}
        },
        "required": ["name", "description", "tool_type"]
      }
    },
    // {
    //   "name": "unregister_tool",
    //   "description": "Remove tool from tool index. Params: name(required). Ex: unregister_tool({name:'deprecated-skill'})",
    //   "parameters": {
    //     "type": "object",
    //     "properties": {
    //       "name": {"type": "string", "description": "要移除的工具名称"}
    //     },
    //     "required": ["name"]
    //   }
    // },
    // {
    //   "name": "update_tool_config",
    //   "description": "Update tool configuration like enabled status or memory index settings. Params: name(required), enabled(optional), add_to_memory(optional). Ex: update_tool_config({name:'web-search', add_to_memory:false})",
    //   "parameters": {
    //     "type": "object",
    //     "properties": {
    //       "name": {"type": "string", "description": "工具名称"},
    //       "enabled": {"type": "boolean", "description": "是否启用"},
    //       "add_to_memory": {"type": "boolean", "description": "是否加入记忆索引"}
    //     },
    //     "required": ["name"]
    //   }
    // }
  ],

  // ==========================================
  // 浏览器操作工具（合并优化版：11→4）
  // 对应 BrowserTool 类中的方法
  // ==========================================
  "browser_tools": [
    {
      "name": "browser_action",
      "method": "action",
      "description": "执行页面交互操作。action类型：click(点击)、input(输入)、scroll(滚动)、send_keys(按键)。Ex: browser_action({action:'click', index:5}) 或 browser_action({action:'input', index:10, text:'hello'})",
      "parameters": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": ["click", "input", "scroll", "send_keys"],
            "description": "操作类型"
          },
          "index": {"type": "integer", "description": "元素索引（click/input时需要）"},
          "text": {"type": "string", "description": "输入文本（input时需要）"},
          "clear": {"type": "boolean", "description": "是否清空输入框", "default": true},
          "direction": {"type": "string", "enum": ["up", "down"], "description": "滚动方向（scroll时需要）", "default": "down"},
          "pages": {"type": "number", "description": "滚动页数", "default": 1.0},
          "keys": {"type": "string", "description": "按键序列（send_keys时需要）"}
        },
        "required": ["action"]
      }
    },
    {
      "name": "browser_navigate",
      "method": "navigate",
      "description": "页面导航操作。action类型：navigate(打开URL)、back(后退)、forward(前进)。Ex: browser_navigate({url:'https://example.com'}) 或 browser_navigate({action:'back'})",
      "parameters": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": ["navigate", "back", "forward"],
            "default": "navigate",
            "description": "导航动作"
          },
          "url": {"type": "string", "description": "目标URL（navigate时需要）"}
        },
        "required": []
      }
    },
    {
      "name": "browser_tab",
      "method": "tab",
      "description": "标签页管理。action类型：list(列出所有)、switch(切换)、close(关闭)。Ex: browser_tab({action:'list'}) 或 browser_tab({action:'switch', tab_index:1})",
      "parameters": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": ["list", "switch", "close"],
            "description": "操作类型"
          },
          "tab_index": {"type": "integer", "description": "标签页索引（switch时需要）"}
        },
        "required": ["action"]
      }
    },
    {
      "name": "browser_read",
      "method": "read",
      "description": "读取页面信息。action类型：state(获取页面状态和交互元素)、extract(提取页面内容)。Ex: browser_read({action:'state'}) 或 browser_read({action:'extract', selector:'article'})",
      "parameters": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": ["state", "extract"],
            "default": "state",
            "description": "读取类型"
          },
          "mode": {"type": "string", "enum": ["interactive", "minimal", "full"], "default": "interactive", "description": "提取模式（state时使用）"},
          "max_elements": {"type": "integer", "default": 20, "description": "最大返回元素数"},
          "prioritize_visible": {"type": "boolean", "default": true, "description": "仅包含可见元素"},
          "include_summary": {"type": "boolean", "default": true, "description": "包含页面摘要"},
          "selector": {"type": "string", "description": "CSS选择器（extract时使用）"},
          "format": {"type": "string", "enum": ["text", "markdown"], "default": "text", "description": "输出格式（extract时使用）"}
        },
        "required": ["action"]
      }
    }
  ]


  
}
