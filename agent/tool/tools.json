// FicusBot 工具配置文件
// 支持 JSON5 格式，允许添加注释
// 工具定义从此文件加载，支持 file、shell、skill 三类工具
// 工具命名规范：使用下划线分隔，如 file_read、shell_exec（兼容 DeepSeek 等模型）

{
  // ==========================================
  // 文件操作工具
  // 对应 FileSystemTool 类中的方法
  // ==========================================
  "file_tools": [
    {
      "name": "file_read",           // 工具唯一标识符
      "method": "read",              // FileSystemTool 中的方法名
      "description": "Read file content. View code, configs, docs. Params: file_path required, encoding optional (utf-8). Ex: file_read({file_path:'src/main.py'})",
      "parameters": {
        "type": "object",
        "properties": {
          "file_path": {"type": "string", "description": "文件路径（相对路径或绝对路径）"},
          "encoding": {"type": "string", "description": "文件编码，默认utf-8"}
        },
        "required": ["file_path"]
      }
    },
    {
      "name": "file_write",
      "method": "write",
      "description": "Create or overwrite file. Write code, configs, text. Params: file_path required, content required, overwrite optional (true). Ex: file_write({file_path:'test.py',content:'print(1)' })",
      "parameters": {
        "type": "object",
        "properties": {
          "file_path": {"type": "string", "description": "文件路径（相对路径或绝对路径）"},
          "content": {"type": "string", "description": "写入内容"},
          "overwrite": {"type": "boolean", "description": "是否覆盖，默认true"}
        },
        "required": ["file_path", "content"]
      }
    },
    {
      "name": "file_append",
      "method": "append",
      "description": "Append content to file end. Add logs, comments. Params: file_path required, content required. Ex: file_append({file_path:'log.txt',content:'new line'})",
      "parameters": {
        "type": "object",
        "properties": {
          "file_path": {"type": "string", "description": "文件路径（相对路径或绝对路径）"},
          "content": {"type": "string", "description": "追加内容"}
        },
        "required": ["file_path", "content"]
      }
    },
    {
      "name": "file_list_dir",
      "method": "list_dir",
      "description": "List directory contents. MUST use a confirmed path. Params: dir_path optional, show_hidden optional. Ex: file_list_dir({dir_path:'src'})",
      "parameters": {
        "type": "object",
        "properties": {
          "dir_path": {"type": "string", "description": "目录路径（相对路径或绝对路径，必须是已确认的路径），默认当前目录"},
          "show_hidden": {"type": "boolean", "description": "是否显示隐藏文件，默认false"}
        }
      }
    },
    {
      "name": "file_find",
      "method": "find",
      "description": "Recursively search files. MUST use a confirmed root_path. Params: root_path required, pattern optional, file_type optional, content_keyword optional. Ex: file_find({root_path:'.',pattern:'*.py'})",
      "parameters": {
        "type": "object",
        "properties": {
          "root_path": {"type": "string", "description": "搜索根目录路径（相对路径或绝对路径，必须是已确认的路径），默认当前目录"},
          "pattern": {"type": "string", "description": "文件名通配符"},
          "file_type": {"type": "string", "description": "类型过滤：all/file/dir，默认all"},
          "content_keyword": {"type": "string", "description": "文件内容关键词"}
        }
      }
    },
    {
      "name": "file_exists",
      "method": "exists",
      "description": "Check if file or directory exists. Validate path. Params: path required. Ex: file_exists({path:'src'})",
      "parameters": {
        "type": "object",
        "properties": {
          "path": {"type": "string", "description": "文件/目录路径（相对路径或绝对路径）"}
        },
        "required": ["path"]
      }
    },
    {
      // 获取系统特殊文件夹路径
      // Windows: 使用 PowerShell [Environment]::GetFolderPath()
      // Linux/Mac: 使用 xdg-user-dir 或环境变量
      // 支持中英文名称：Desktop/桌面, Downloads/下载, Documents/文档等
      "name": "file_get_system_folder",
      "method": "get_system_folder",
      "description": "Get system special folder path (Windows/Linux/Mac). Retrieve Desktop, Downloads, Documents, Pictures, Videos, Music folders. Supports both English and Chinese names. Returns absolute path for file operations. Use this first before file_list_dir/file_find when targeting system folders. Params: folder_name required. Ex: file_get_system_folder({folder_name:'Desktop'})",
      "parameters": {
        "type": "object",
        "properties": {
          "folder_name": {"type": "string", "description": "文件夹名称，支持Desktop(桌面)/Downloads(下载)/Documents(文档)/Pictures(图片)/Videos(视频)/Music(音乐)/UserProfile(用户目录)，支持Windows/Linux/Mac"}
        },
        "required": ["folder_name"]
      }
    }
  ],

  // ==========================================
  // Shell 命令工具
  // 对应 ShellTool 类中的方法
  // ==========================================
  "shell_tools": [
    {
      "name": "shell_exec",
      "method": "exec",
      "description": "Execute shell command. Run programs, scripts, file ops. Params: cmd required, cwd optional. Ex: shell_exec({cmd:'python test.py'})",
      "parameters": {
        "type": "object",
        "properties": {
          "cmd": {"type": "string", "description": "要执行的Shell命令"},
          "cwd": {"type": "string", "description": "工作目录，默认当前目录"}
        },
        "required": ["cmd"]
      }
    }
  ],

  // ==========================================
  // 技能工具配置
  // 从 workspace/skills 目录动态加载
  // ==========================================
  "skill_tools": {
    "enabled": true,                    // 是否启用技能系统
    "description": "Load and execute custom skills from workspace/skills directory"
  },

  // ==========================================
  // 记忆系统工具
  // 用于存储和检索长期记忆
  // ==========================================
  "memory_tools": [
    {
      "name": "save_memory",
      "description": "保存信息到长期记忆。存储用户偏好、事实、任务结果等。",
      "parameters": {
        "type": "object",
        "properties": {
          "content": {"type": "string", "description": "要保存的记忆内容，应简洁明了"},
          "memory_type": {
            "type": "string",
            "enum": ["conversation", "fact", "preference", "task", "insight", "document"],
            "description": "记忆类型",
            "default": "conversation"
          },
          "importance": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10,
            "description": "重要性评分，1-10，默认5",
            "default": 5
          },
          "tags": {
            "type": "array",
            "items": {"type": "string"},
            "description": "标签列表"
          }
        },
        "required": ["content"]
      }
    },
    {
      "name": "search_memory",
      "description": "搜索长期记忆或工具。使用场景：(1)查询用户偏好、历史决策、先前工作时，search_type='memory'；(2)常驻工具和技能列表都无法满足需求，需要发现新工具时，search_type='tool'；(3)不确定时用 search_type='all'。",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {"type": "string", "description": "搜索查询，使用自然语言描述要查找的内容"},
          "search_type": {
            "type": "string",
            "enum": ["all", "memory", "tool"],
            "description": "搜索范围：memory(用户记忆/偏好/事实), tool(搜索可用工具/技能), all(全部)",
            "default": "all"
          },
          "top_k": {
            "type": "integer",
            "description": "返回结果数量，默认10",
            "default": 10
          }
        },
        "required": ["query"]
      }
    },
    {
      "name": "delete_memory",
      "description": "删除指定ID的记忆。",
      "parameters": {
        "type": "object",
        "properties": {
          "memory_id": {"type": "string", "description": "要删除的记忆ID"}
        },
        "required": ["memory_id"]
      }
    },
    {
      "name": "register_tool",
      "description": "注册新工具到索引。用于创建技能或发现新工具时注册。",
      "parameters": {
        "type": "object",
        "properties": {
          "name": {"type": "string", "description": "工具名称，唯一标识"},
          "description": {"type": "string", "description": "工具功能描述，用于语义搜索匹配"},
          "tool_type": {
            "type": "string",
            "enum": ["skill", "mcp_server", "builtin"],
            "description": "工具类型"
          },
          "source": {"type": "string", "description": "工具来源路径或标识"},
          "enabled": {"type": "boolean", "description": "是否启用，默认true", "default": true},
          "add_to_memory": {"type": "boolean", "description": "是否加入记忆索引（语义搜索），默认true", "default": true}
        },
        "required": ["name", "description", "tool_type"]
      }
    },
    // {
    //   "name": "unregister_tool",
    //   "description": "Remove tool from tool index. Params: name(required). Ex: unregister_tool({name:'deprecated-skill'})",
    //   "parameters": {
    //     "type": "object",
    //     "properties": {
    //       "name": {"type": "string", "description": "要移除的工具名称"}
    //     },
    //     "required": ["name"]
    //   }
    // },
    // {
    //   "name": "update_tool_config",
    //   "description": "Update tool configuration like enabled status or memory index settings. Params: name(required), enabled(optional), add_to_memory(optional). Ex: update_tool_config({name:'web-search', add_to_memory:false})",
    //   "parameters": {
    //     "type": "object",
    //     "properties": {
    //       "name": {"type": "string", "description": "工具名称"},
    //       "enabled": {"type": "boolean", "description": "是否启用"},
    //       "add_to_memory": {"type": "boolean", "description": "是否加入记忆索引"}
    //     },
    //     "required": ["name"]
    //   }
    // }
  ],

  // ==========================================
  // 浏览器操作工具
  // 对应 BrowserTool 类中的方法
  // ==========================================
  "browser_tools": [
    {
      "name": "browser_navigate",
      "method": "navigate",
      "description": "Navigate to URL. Open webpage. Params: url(required). Ex: browser_navigate({url:'https://example.com'})",
      "parameters": {
        "type": "object",
        "properties": {
          "url": {"type": "string", "description": "目标URL"}
        },
        "required": ["url"]
      }
    },
    {
      "name": "browser_click",
      "method": "click",
      "description": "Click element by index. Params: index(required, element index from page state). Ex: browser_click({index:5})",
      "parameters": {
        "type": "object",
        "properties": {
          "index": {"type": "integer", "description": "页面状态中的元素索引"}
        },
        "required": ["index"]
      }
    },
    {
      "name": "browser_input",
      "method": "input_text",
      "description": "Input text into element. Params: index(required), text(required), clear(optional, default true). Ex: browser_input({index:10, text:'hello'})",
      "parameters": {
        "type": "object",
        "properties": {
          "index": {"type": "integer", "description": "元素索引"},
          "text": {"type": "string", "description": "输入文本"},
          "clear": {"type": "boolean", "description": "是否先清空输入框", "default": true}
        },
        "required": ["index", "text"]
      }
    },
    {
      "name": "browser_scroll",
      "method": "scroll",
      "description": "Scroll page. Params: direction(optional, up/down, default down), pages(optional, default 1). Ex: browser_scroll({direction:'down', pages:1})",
      "parameters": {
        "type": "object",
        "properties": {
          "direction": {"type": "string", "enum": ["up", "down"], "description": "滚动方向", "default": "down"},
          "pages": {"type": "number", "description": "滚动页数", "default": 1.0}
        },
        "required": []
      }
    },
    {
      "name": "browser_extract",
      "method": "extract",
      "description": "Extract page content as plain text. Use format='markdown' only if user explicitly needs markdown format. Ex: browser_extract({}) or browser_extract({selector:'article'})",
      "parameters": {
        "type": "object",
        "properties": {
          "selector": {"type": "string", "description": "CSS选择器（可选，为空则提取整个页面）"},
          "format": {"type": "string", "enum": ["text", "markdown"], "description": "输出格式（默认text），仅在明确需要时使用markdown", "default": "text"}
        },
        "required": []
      }
    },
    {
      "name": "browser_send_keys",
      "method": "send_keys",
      "description": "Send keyboard keys. Params: keys(required). Ex: browser_send_keys({keys:'Enter'}) or browser_send_keys({keys:'Control+A'})",
      "parameters": {
        "type": "object",
        "properties": {
          "keys": {"type": "string", "description": "按键序列，如 Enter, Tab, Escape, Control+A"}
        },
        "required": ["keys"]
      }
    },
    {
      "name": "browser_go_back",
      "method": "go_back",
      "description": "Go back to previous page. No params. Ex: browser_go_back({})",
      "parameters": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "browser_get_state",
      "method": "get_state",
      "description": "Get page state with clickable elements. Returns URL, title, element list and page summary. Token-optimized with configurable mode.",
      "parameters": {
        "type": "object",
        "properties": {
          "mode": {
            "type": "string",
            "enum": ["interactive", "minimal", "full"],
            "description": "提取模式: interactive(仅交互元素), minimal(仅核心元素), full(所有元素). 默认: interactive",
            "default": "interactive"
          },
          "max_elements": {
            "type": "integer",
            "description": "最大返回元素数（默认20，范围5-50）",
            "default": 20
          },
          "prioritize_visible": {
            "type": "boolean",
            "description": "仅包含视口可见元素（默认true）",
            "default": true
          },
          "include_summary": {
            "type": "boolean",
            "description": "包含页面文本摘要（默认true）",
            "default": true
          }
        },
        "required": []
      }
    },
    {
      "name": "browser_switch_tab",
      "method": "switch_tab",
      "description": "Switch to tab by index. Params: tab_index(required). Ex: browser_switch_tab({tab_index:1})",
      "parameters": {
        "type": "object",
        "properties": {
          "tab_index": {"type": "integer", "description": "标签页索引（从0开始）"}
        },
        "required": ["tab_index"]
      }
    },
    {
      "name": "browser_close_tab",
      "method": "close_tab",
      "description": "Close current tab. No params. Ex: browser_close_tab({})",
      "parameters": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "browser_list_tabs",
      "method": "list_tabs",
      "description": "List all open tabs. No params. Ex: browser_list_tabs({})",
      "parameters": {
        "type": "object",
        "properties": {},
        "required": []
      }
    }
  ]
}
