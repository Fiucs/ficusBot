    //     }
    //   }
    // },
    {
      "name": "file_exists",
      "method": "exists",
      "description": "Check if file or directory exists. Validate path. Params: path required. Ex: file_exists({path:'src'})",
      "parameters": {
        "type": "object",
        "properties": {
          "path": {"type": "string", "description": "文件/目录路径（相对路径或绝对路径）"}
        },
        "required": ["path"]
      }
    },
    // {
    //   // 获取系统特殊文件夹路径
    //   // Windows: 使用 PowerShell [Environment]::GetFolderPath()
