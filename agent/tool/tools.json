// FicusBot 工具配置文件
// 支持 JSON5 格式，允许添加注释
// 工具定义从此文件加载，支持 file、shell、skill 三类工具
// 工具命名规范：使用下划线分隔，如 file_read、shell_exec（兼容 DeepSeek 等模型）

{
  // ==========================================
  // 文件操作工具
  // 对应 FileSystemTool 类中的方法
  // ==========================================
  "file_tools": [
    {
      "name": "file_read",           // 工具唯一标识符
      "method": "read",              // FileSystemTool 中的方法名
      "description": "Read file content. View code, configs, docs. Params: file_path required, encoding optional (utf-8). Ex: file_read({file_path:'src/main.py'})",
      "parameters": {
        "type": "object",
        "properties": {
          "file_path": {"type": "string", "description": "文件路径（相对路径或绝对路径）"},
          "encoding": {"type": "string", "description": "文件编码，默认utf-8"}
        },
        "required": ["file_path"]
      }
    },
    {
      "name": "file_write",
      "method": "write",
      "description": "创建新文件，完全覆盖写入文件。参数: file_path(必填,文件路径), content(必填,写入内容), overwrite(可选,是否覆盖,默认true)。使用前请确认是否需要保留原文件内容，如需追加请使用file_append。",
      "parameters": {
        "type": "object",
        "properties": {
          "file_path": {"type": "string", "description": "文件路径（相对路径或绝对路径）"},
          "content": {"type": "string", "description": "写入内容"},
          "overwrite": {"type": "boolean", "description": "是否覆盖，默认true"}
        },
        "required": ["file_path", "content"]
      }
    },
    {
      "name": "file_append",
      "method": "append",
      "description": "write content to file end. Add logs, comments. Params: file_path required, content required. Ex: file_append({file_path:'log.txt',content:'new line'})",
      "parameters": {
        "type": "object",
        "properties": {
          "file_path": {"type": "string", "description": "文件路径（相对路径或绝对路径）"},
          "content": {"type": "string", "description": "追加内容"}
        },
        "required": ["file_path", "content"]
      }
    },
    // {
    //   "name": "file_list_dir",
    //   "method": "list_dir",
    //   "description": "List directory contents. MUST use a confirmed path. Params: dir_path optional, show_hidden optional. Ex: file_list_dir({dir_path:'src'})",
    //   "parameters": {
    //     "type": "object",
    //     "properties": {
    //       "dir_path": {"type": "string", "description": "目录路径（相对路径或绝对路径，必须是已确认的路径），默认当前目录"},
    //       "show_hidden": {"type": "boolean", "description": "是否显示隐藏文件，默认false"}
    //     }
    //   }
    // },
    // {
    //   "name": "file_find",
    //   "method": "find",
    //   "description": "Recursively search files. MUST use a confirmed root_path. Params: root_path required, pattern optional, file_type optional, content_keyword optional. Ex: file_find({root_path:'.',pattern:'*.py'})",
    //   "parameters": {
    //     "type": "object",
    //     "properties": {
    //       "root_path": {"type": "string", "description": "搜索根目录路径（相对路径或绝对路径，必须是已确认的路径），默认当前目录"},
    //       "pattern": {"type": "string", "description": "文件名通配符"},
