// FicusBot 工具配置文件
// 支持 JSON5 格式，允许添加注释
// 工具定义从此文件加载，支持 file、shell、skill 三类工具

{
  // ==========================================
  // 文件操作工具
  // 对应 FileSystemTool 类中的方法
  // ==========================================
  "file_tools": [
    {
      "name": "file.read",           // 工具唯一标识符
      "method": "read",              // FileSystemTool 中的方法名
      "description": "Read file content. View code, configs, docs. Params: file_path required, encoding optional (utf-8). Ex: file.read({file_path:'src/main.py'})",
      "parameters": {
        "type": "object",
        "properties": {
          "file_path": {"type": "string", "description": "文件路径（相对路径或绝对路径）"},
          "encoding": {"type": "string", "description": "文件编码，默认utf-8"}
        },
        "required": ["file_path"]
      }
    },
    {
      "name": "file.write",
      "method": "write",
      "description": "Create or overwrite file. Write code, configs, text. Params: file_path required, content required, overwrite optional (true). Ex: file.write({file_path:'test.py',content:'print(1)' })",
      "parameters": {
        "type": "object",
        "properties": {
          "file_path": {"type": "string", "description": "文件路径（相对路径或绝对路径）"},
          "content": {"type": "string", "description": "写入内容"},
          "overwrite": {"type": "boolean", "description": "是否覆盖，默认true"}
        },
        "required": ["file_path", "content"]
      }
    },
    {
      "name": "file.append",
      "method": "append",
      "description": "Append content to file end. Add logs, comments. Params: file_path required, content required. Ex: file.append({file_path:'log.txt',content:'new line'})",
      "parameters": {
        "type": "object",
        "properties": {
          "file_path": {"type": "string", "description": "文件路径（相对路径或绝对路径）"},
          "content": {"type": "string", "description": "追加内容"}
        },
        "required": ["file_path", "content"]
      }
    },
    {
      "name": "file.mkdir",
      "method": "mkdir",
      "description": "Create directory. Build project structure. Params: dir_path required, recursive optional (true). Ex: file.mkdir({dir_path:'src/utils'})",
      "parameters": {
        "type": "object",
        "properties": {
          "dir_path": {"type": "string", "description": "目录路径（相对路径或绝对路径）"},
          "recursive": {"type": "boolean", "description": "是否递归创建，默认true"}
        },
        "required": ["dir_path"]
      }
    },
    {
      "name": "file.list_dir",
      "method": "list_dir",
      "description": "List directory contents. MUST use a confirmed path. Params: dir_path optional, show_hidden optional. Ex: file.list_dir({dir_path:'src'})",
      "parameters": {
        "type": "object",
        "properties": {
          "dir_path": {"type": "string", "description": "目录路径（相对路径或绝对路径，必须是已确认的路径），默认当前目录"},
          "show_hidden": {"type": "boolean", "description": "是否显示隐藏文件，默认false"}
        }
      }
    },
    {
      "name": "file.find",
      "method": "find",
      "description": "Recursively search files. MUST use a confirmed root_path. Params: root_path required, pattern optional, file_type optional, content_keyword optional. Ex: file.find({root_path:'.',pattern:'*.py'})",
      "parameters": {
        "type": "object",
        "properties": {
          "root_path": {"type": "string", "description": "搜索根目录路径（相对路径或绝对路径，必须是已确认的路径），默认当前目录"},
          "pattern": {"type": "string", "description": "文件名通配符"},
          "file_type": {"type": "string", "description": "类型过滤：all/file/dir，默认all"},
          "content_keyword": {"type": "string", "description": "文件内容关键词"}
        }
      }
    },
    {
      "name": "file.exists",
      "method": "exists",
      "description": "Check if file or directory exists. Validate path. Params: path required. Ex: file.exists({path:'src'})",
      "parameters": {
        "type": "object",
        "properties": {
          "path": {"type": "string", "description": "文件/目录路径（相对路径或绝对路径）"}
        },
        "required": ["path"]
      }
    },
    {
      "name": "file.move",
      "method": "move",
      "description": "Move file or directory. Relocate files. Params: source_path required, target_path required. Ex: file.move({source_path:'a.txt',target_path:'b.txt'})",
      "parameters": {
        "type": "object",
        "properties": {
          "source_path": {"type": "string", "description": "源路径（相对路径或绝对路径）"},
          "target_path": {"type": "string", "description": "目标路径（相对路径或绝对路径）"}
        },
        "required": ["source_path", "target_path"]
      }
    },
    {
      "name": "file.copy",
      "method": "copy",
      "description": "Copy file or directory. Backup files. Params: source_path required, target_path required, overwrite optional (false). Ex: file.copy({source_path:'a.txt',target_path:'b.txt'})",
      "parameters": {
        "type": "object",
        "properties": {
          "source_path": {"type": "string", "description": "源路径（相对路径或绝对路径）"},
          "target_path": {"type": "string", "description": "目标路径（相对路径或绝对路径）"},
          "overwrite": {"type": "boolean", "description": "是否覆盖，默认false"}
        },
        "required": ["source_path", "target_path"]
      }
    },
    {
      "name": "file.delete",
      "method": "delete",
      "description": "Delete file or directory. Remove temp files. Params: path required, recursive optional, force optional. Ex: file.delete({path:'temp.txt'})",
      "parameters": {
        "type": "object",
        "properties": {
          "path": {"type": "string", "description": "文件/目录路径（相对路径或绝对路径）"},
          "recursive": {"type": "boolean", "description": "递归删除目录，默认false"},
          "force": {"type": "boolean", "description": "强制删除目录，默认false"}
        },
        "required": ["path"]
      }
    },
    {
      // 获取系统特殊文件夹路径
      // Windows: 使用 PowerShell [Environment]::GetFolderPath()
      // Linux/Mac: 使用 xdg-user-dir 或环境变量
      // 支持中英文名称：Desktop/桌面, Downloads/下载, Documents/文档等
      "name": "file.get_system_folder",
      "method": "get_system_folder",
      "description": "Get system special folder path (Windows/Linux/Mac). Retrieve Desktop, Downloads, Documents, Pictures, Videos, Music folders. Supports both English and Chinese names. Returns absolute path for file operations. Use this first before file.list_dir/file.find when targeting system folders. Params: folder_name required. Ex: file.get_system_folder({folder_name:'Desktop'})",
      "parameters": {
        "type": "object",
        "properties": {
          "folder_name": {"type": "string", "description": "文件夹名称，支持Desktop(桌面)/Downloads(下载)/Documents(文档)/Pictures(图片)/Videos(视频)/Music(音乐)/UserProfile(用户目录)，支持Windows/Linux/Mac"}
        },
        "required": ["folder_name"]
      }
    }
  ],

  // ==========================================
  // Shell 命令工具
  // 对应 ShellTool 类中的方法
  // ==========================================
  "shell_tools": [
    {
      "name": "shell.exec",
      "method": "exec",
      "description": "Execute shell command. Run programs, scripts, file ops. Params: cmd required, cwd optional. Ex: shell.exec({cmd:'python test.py'})",
      "parameters": {
        "type": "object",
        "properties": {
          "cmd": {"type": "string", "description": "要执行的Shell命令"},
          "cwd": {"type": "string", "description": "工作目录，默认当前目录"}
        },
        "required": ["cmd"]
      }
    }
  ],

  // ==========================================
  // 技能工具配置
  // 从 workspace/skills 目录动态加载
  // ==========================================
  "skill_tools": {
    "enabled": true,                    // 是否启用技能系统
    "description": "Load and execute custom skills from workspace/skills directory"
  }
}
